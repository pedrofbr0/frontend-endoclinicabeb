# Server-side only. Used by the contact form API to save leads in Sanity.
SANITY_API_WRITE_TOKEN=

# Server-side only. Used by the on-demand revalidation API (/api/revalidate).
# Must match the Authorization header secret configured in the Sanity webhook.
SANITY_REVALIDATE_SECRET=

# Public URL used for canonical URLs and Open Graph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. Only set these if you need to override the defaults in src/lib/sanity.ts.
NEXT_PUBLIC_SANITY_PROJECT_ID=olc9cotp
NEXT_PUBLIC_SANITY_DATASET=production
